[sub_resource type="GDScript" id="GDScript_6hk3s"]
resource_name = "AnimationController"
script/source = "extends MeshInstance3D


@onready var animation_player: AnimationPlayer = $\"../AnimationPlayer\"
@export_range(0.0, 1.0) var slider: float


func _ready() -> void:
	animation_player.play(\"new_animation\")
	animation_player.pause()
	pass
	

func _process(delta: float) -> void:
	var l = animation_player.current_animation_length
	#animation_player.seek(l * slider, true) 
	animation_player.advance(slider)
	pass
"

